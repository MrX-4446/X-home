<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="60dp"
    android:layout_height="180dp"
    android:background="@drawable/float_bg"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp">

    <ImageButton
        android:id="@+id/btn_ocr"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_ocr"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="OCR识别" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E5E5"
        android:layout_marginVertical="8dp" />

    <ImageButton
        android:id="@+id/btn_notes"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_notes"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="打开笔记" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E5E5"
        android:layout_marginVertical="8dp" />

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="关闭悬浮窗" />

</LinearLayout>
