# =============================================================
# QQ 机器人配置文件
# 使用方法：复制为 .env.qq，修改配置后运行：node qq-bridge.js
# =============================================================

# ──────────────────────────────────────
# go-cqhttp WebSocket 配置
# ──────────────────────────────────────

# go-cqhttp 的 WebSocket 地址（默认反向 WS 端口）
QQ_WS_URL=ws://127.0.0.1:8080

# ──────────────────────────────────────
# AI 接口配置（支持本地或远程服务器）
# ──────────────────────────────────────

# AI 聊天 API 地址
# - 本地部署: http://localhost:8888/api/chat
# - 服务器部署: https://your-domain.com/api/chat
AI_API_URL=http://localhost:8888/api/chat

# 如果 API 需要认证密钥（可选）
AI_API_KEY=

# ──────────────────────────────────────
# 机器人基本信息
# ──────────────────────────────────────

# 机器人 QQ 号（用于判断是否被@）
BOT_QQ=123456789

# 轩的 QQ 号 - 只有这个号码能触发恋人模式 💕
# 其他号码都是普通朋友模式
OWNER_QQ=987654321

# ──────────────────────────────────────
# 辅助AI配置（做摘要/压缩等后台任务）
# 主AI专心谈恋爱，脏活累活交给辅助AI
# ──────────────────────────────────────

# 辅助AI接口地址（和主AI用同一个也可以）
HELPER_API_URL=http://localhost:8888/api/chat

# 辅助AI的API Key（如果需要）
HELPER_API_KEY=

# 触发AI智能摘要的阈值
# 消息超过这个长度才调用AI，短消息直接用规则压缩省token
AI_SUMMARY_THRESHOLD=300

# ──────────────────────────────────────
# 权限控制
# ──────────────────────────────────────

# 允许的群号，逗号分隔（留空表示允许所有群）
# 例子：ALLOWED_GROUPS=123456,789012
ALLOWED_GROUPS=

# 允许的 QQ 号，逗号分隔（留空表示允许所有用户）
# 例子：ALLOWED_USERS=11111,22222
ALLOWED_USERS=

# ──────────────────────────────────────
# 触发设置
# ──────────────────────────────────────

# 群聊中是否需要@机器人才响应
REQUIRE_AT_IN_GROUP=true

# 触发前缀（可选，群聊中可以用前缀代替@）
# 例子：TRIGGER_PREFIX=小爱
TRIGGER_PREFIX=

# ──────────────────────────────────────
# 其他配置
# ──────────────────────────────────────

# QQ 桥接服务管理端口（用于健康检查等）
QQ_BRIDGE_PORT=8765
