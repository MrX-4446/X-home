# =============================================================
# 后端环境配置文件
# 使用说明：复制为 .env 并填入实际值
# =============================================================

# 服务器端口
PORT=8888

# Supabase 数据库配置（生产环境需要填写真实值）
# 如果不需要数据库，可以设置为 localhost 启用 Mock 模式
SUPABASE_URL=localhost
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 火山方舟 API Key（AI 模型调用）
ARK_API_KEY=your-ark-api-key

# CORS 允许的域名（生产环境建议限制为实际域名）
ALLOWED_ORIGINS=*

# ──────────────────────────────────────
# 辅助AI配置（专门做记忆压缩、关键词提取等后台任务）
# 用低成本模型做脏活累活，不影响主AI人设，节省Token
# ──────────────────────────────────────

# 辅助AI提供商ID（对应ai_providers表中的id）
# 设置后，记忆压缩、关键词提取等后台任务会自动使用该AI
HELPER_AI_PROVIDER_ID=

# （可选）如果辅助AI使用独立的API地址
HELPER_API_URL=

# （可选）辅助AI的API密钥
HELPER_API_KEY=
