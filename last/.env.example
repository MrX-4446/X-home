# =============================================================
# 后端环境配置文件
# 使用说明：复制为 .env 并填入实际值
# =============================================================

# 服务器端口
PORT=8888

# Supabase 数据库配置（生产环境需要填写真实值）
# 如果不需要数据库，可以设置为 localhost 启用 Mock 模式
SUPABASE_URL=localhost
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 火山方舟 API Key（AI 模型调用）
ARK_API_KEY=your-ark-api-key

# 博查搜索 API Key（网页搜索工具，国内直连、与模型厂商解耦）
# 前往 https://open.bochaai.com/ 注册并在「API KEY 管理」中创建
BOCHA_API_KEY=your-bocha-api-key

# ──────────────────────────────────────
# 极光推送 JPush（路线 B：AI 消息推到设备通知栏，App 关闭也能收）
# 前往 https://www.jiguang.cn/ 注册应用，包名须与 App 一致：com.x.home
# AppKey 同时要填到前端 capacitor.config.json 与 android/app/build.gradle 的 JPUSH_APPKEY
# ──────────────────────────────────────
JPUSH_APP_KEY=your-jpush-appkey
JPUSH_MASTER_SECRET=your-jpush-master-secret
# APNs 生产环境（iOS）；Android 可忽略，默认 true
JPUSH_PRODUCTION=true

# CORS 允许的域名（生产环境建议限制为实际域名）
ALLOWED_ORIGINS=*

# ──────────────────────────────────────
# 主聊天AI（前端已移除模型选择器，主AI由此固定）
# 值 = 已在前端「AI 接入」里添加并启用的某条接入的 id。
# 用法：① 前端新增并启用一条主聊天模型 ② 复制其 id 填到下面 ③ pm2 restart 生效
# 留空则自动使用启用列表里的第一条接入作为主AI。
# ──────────────────────────────────────
MAIN_AI_PROVIDER_ID=

# ──────────────────────────────────────
# 辅助AI配置（专门做记忆压缩、关键词提取等后台任务）
# 用低成本模型做脏活累活，不影响主AI人设，节省Token
# ──────────────────────────────────────

# 辅助AI提供商ID = 已在前端「AI 接入」里添加并启用的某条接入的 id
# 该接入自带模型/端点/API Key，无需在此另配。留空则自动回退用主AI。
# 用法：① 前端新增一条低成本模型接入 ② 复制其 id 填到下面 ③ pm2 restart 生效
HELPER_AI_PROVIDER_ID=

# ──────────────────────────────────────
# 视觉副模型（读图 → 文字描述，让纯文本主AI「看懂」图片）
# 聊天里发图片时，后端自动调该模型把图转成「[图片：描述]」再喂给主AI，带缓存不重复烧钱。
# 用法：① 在前端「AI 接入」新增一条支持图片输入的多模态模型（如火山 doubao-vision，endpoint 同主AI）
#      ② 把该接入的 id 填到下面 ③ pm2 restart 生效
# 不填则发图自动降级为「[图片]」占位，不影响主流程。
# ──────────────────────────────────────
VISION_AI_PROVIDER_ID=

# ──────────────────────────────────────
# 任务副模型（预留：搜索/比价/代码等「任务简报」执行者）
# 端口已通但暂未接入调度逻辑。未来配好此 id 并用 callAIProvider(.., { role:'task' }) 即可启用。
# ──────────────────────────────────────
TASK_AI_PROVIDER_ID=

# ──────────────────────────────────────
# 自我画像层（overlay：X 在与轩长期相处中形成的相处风格/默契/近期状态）
# 与 base-rules.md 分权：base-rules 是不可变护栏与底色，画像层只记相处方式，注入排在其后。
# ──────────────────────────────────────
# 是否开启"自动抽取画像"（默认开启）。
# 设为 false/0/off 则关闭自动抽取，仅保留面板手动加画像（辅助AI能力不稳时的降级兜底）。
SELF_PORTRAIT_AUTO=true
